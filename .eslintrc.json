{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "jest": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "error",
    "eqeqeq": ["warn", "smart"],
    "prefer-const": "warn"
  },
  "globals": {
    "Chart": "readonly"
  }
}
